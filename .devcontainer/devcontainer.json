{
  "name": "JavaGui",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "containerEnv": {
    "DISPLAY": ":0",
    "VNC_RESOLUTION": "1280x720",
    "VNC_PASSWORD": "vscode"
  },
  "remoteEnv": {
    "DISPLAY": ":0",
    "VNC_RESOLUTION": "1280x720"
  },
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "21",
      "jdkDistro": "ms"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "formulahendry.code-runner",
        "GitHub.copilot"
      ],
      "settings": {
        "code-runner.runInTerminal": true,
        "code-runner.executorMap": {
          "java": "cd $dir && javac $fileName && java ${fileBasenameNoExtension}"
        },
        "java.project.referencedLibraries": [
          "/var/libs/stdlib.jar"
        ],
        "files.exclude": {
          "**/.devcontainer": true,
          "**/.vscode": true,
          "**/.github": true
        }
      }
    }
  },
  "forwardPorts": [
    6080
  ],
  "portsAttributes": {
    "6080": {
      "label": "Desktop (noVNC)",
      "onAutoForward": "openBrowser"
    }
  },
  "postStartCommand": "supervisord -c /etc/supervisor/conf.d/supervisord-novnc.conf",
  "postCreateCommand": "bash .devcontainer/health-check.sh"
}
